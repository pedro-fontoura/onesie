import stampit2 from "stampit";
import { ARRAY_TYPE } from "glMatrix";
import { fromValues, create } from "vec2";
var vec2 = { fromValues, create };
var V8 = stampit2({
  methods: {
    /**
     * Safely validates and returns a new vec2 instance.
     * @param {Array|Float32Array} input_value - The user-provided vector (or null/undefined).
     * @param {Array|Float32Array} [default_values] - The optional default value if input is null. Defaults to a zero vector if omitted.
     * @returns {Float32Array} A newly created glMatrix vec2 instance.
     */
    validateVector(input_value, default_values = null) {
      const source_values = input_value || default_values;
      if (!source_values) {
        return vec2.create();
      }
      if (!(Array.isArray(source_values) || source_values instanceof ARRAY_TYPE)) {
        console.error(source_values);
        throw new Error("Vector input must be an Array or glMatrix ARRAY_TYPE.");
      }
      if (source_values.length !== 2) {
        console.error(source_values);
        throw new Error("Vector input must have exactly 2 elements.");
      }
      if (!Number.isFinite(source_values[0]) || !Number.isFinite(source_values[1])) {
        console.error(source_values);
        throw new Error("Vector array must contain only numeric values.");
      }
      return vec2.fromValues(source_values[0], source_values[1]);
    }
  }
});

